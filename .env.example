# =============================================================================
# Compliance Dashboard — environment variables
# =============================================================================
# Copy to .env.local for local dev (use TEST-mode Stripe keys).
# For production, set each variable in Netlify:
#   Site configuration → Environment variables → Add a variable
#   Scope: Builds + Functions   Context: Production (use Deploy Previews for test)
#
# Vars prefixed with VITE_ are bundled into the client JS at build time —
# only put publishable keys and Price IDs there. Everything else stays
# server-side (Netlify Functions only).
# =============================================================================


# ---- Supabase ---------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # server-only, full read/write


# ---- App ---------------------------------------------------------------------
APP_URL=https://app.lydellsecurity.com    # drives Checkout/Portal return URLs


# ---- Stripe: keys & webhook --------------------------------------------------
VITE_STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ---- Stripe: base plan price IDs (client) ------------------------------------
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_...
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_...
VITE_STRIPE_PRICE_GROWTH_MONTHLY=price_...
VITE_STRIPE_PRICE_GROWTH_ANNUAL=price_...
VITE_STRIPE_PRICE_SCALE_MONTHLY=price_...
VITE_STRIPE_PRICE_SCALE_ANNUAL=price_...


# ---- Stripe: base plan price IDs (server mirror) -----------------------------
# Unprefixed duplicates — read by netlify/functions/utils/stripe.cjs for the
# webhook's priceId → plan reverse lookup. Values match the VITE_ ones above.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_ANNUAL=price_...


# ---- Stripe: add-on price IDs (client) ---------------------------------------
# Seat overages (metered, aggregate_usage=last_during_period, metadata.meter=seats)
VITE_STRIPE_PRICE_SEAT_STARTER=price_...
VITE_STRIPE_PRICE_SEAT_GROWTH=price_...
VITE_STRIPE_PRICE_SEAT_SCALE=price_...

# Usage blocks (metered, aggregate_usage=sum, transform_quantity set on Stripe)
VITE_STRIPE_PRICE_AI_POLICY_BLOCK_50=price_...
VITE_STRIPE_PRICE_QUESTIONNAIRE_BLOCK_10=price_...
VITE_STRIPE_PRICE_VENDOR_BLOCK_25=price_...

# Flat recurring + one-off
VITE_STRIPE_PRICE_CSM_MONTHLY=price_...
VITE_STRIPE_PRICE_AUDIT_BUNDLE=price_...


# ---- Stripe: add-on price IDs (server mirror) --------------------------------
# Needed once server-side code starts attaching add-on items at checkout.
STRIPE_ADDON_SEAT_STARTER=price_...
STRIPE_ADDON_SEAT_GROWTH=price_...
STRIPE_ADDON_SEAT_SCALE=price_...
STRIPE_ADDON_AI_POLICY_BLOCK_50=price_...
STRIPE_ADDON_QUESTIONNAIRE_BLOCK_10=price_...
STRIPE_ADDON_VENDOR_BLOCK_25=price_...
STRIPE_ADDON_CSM_MONTHLY=price_...
STRIPE_ADDON_AUDIT_BUNDLE=price_...


# ---- Scheduled usage reporter ------------------------------------------------
# Shared secret for stripe-report-usage. Generate: openssl rand -hex 32
USAGE_REPORT_CRON_SECRET=change-me-to-a-random-32-byte-hex


# ---- AI -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
